<?xml version="1.0" encoding="utf-8"?>
<!-- Enforce TLS for all traffic: call records are personal data and must never
     travel over cleartext HTTP. The Worker is served over HTTPS by Cloudflare. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
